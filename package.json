{
  "name": "cronhive",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Production-grade distributed job scheduler",
  "scripts": {
    "build": "tsc",
    "build:frontend": "cd frontend && npm run build",
    "build:all": "npm run build:frontend && npm run build",
    "dev:dashboard": "cd frontend && npm run dev",
    "dev:api": "tsx watch src/server.ts",
    "dev:scheduler": "tsx watch src/scheduler.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "dev:stack": "concurrently -n api,sched,work,dash -c blue,magenta,green,cyan \"npm run dev:api\" \"npm run dev:scheduler\" \"npm run dev:worker\" \"npm run dev:dashboard\"",
    "start:api": "node dist/server.js",
    "start:scheduler": "node dist/scheduler.js",
    "start:worker": "node dist/worker.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:dev": "prisma migrate dev",
    "lint": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "npm run test && npm run test:integration"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bullmq": "^5.78.1",
    "cors": "^2.8.5",
    "cron-parser": "^5.1.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.6.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.28.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "concurrently": "^9.1.2",
    "prisma": "^6.5.0",
    "testcontainers": "^10.28.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^2.1.9"
  }
}
